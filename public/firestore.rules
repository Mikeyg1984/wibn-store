rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin list
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false; // lock this down (we’ll add you once)
    }

    // Products
    match /products/{id} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Orders
    match /orders/{id} {
      // customers can create orders (invoice requests) without logging in
      allow create: if true;

      // only admins can read/update orders
      allow read, update, delete: if isAdmin();
    }

    // Shipping + site settings
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
